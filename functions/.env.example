# GoHighLevel booking config for the owners lead form.
# Copy to functions/.env and fill in, OR set via the Firebase CLI.
#
# 1) API token (Private Integration in GHL → Settings → Private Integrations,
#    scopes: calendars.readonly, calendars/events.write, contacts.write).
#    Store as a SECRET, not in this file:
#       firebase functions:secrets:set GHL_API_TOKEN
#
# 2) These three are plain params — set them here (functions/.env) or as
#    environment values on deploy:
GHL_CALENDAR_ID=
GHL_LOCATION_ID=
GHL_TIMEZONE=America/Los_Angeles

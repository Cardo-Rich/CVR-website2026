{
  "name": "cvr-website2026",
  "type": "module",
  "version": "0.1.0",
  "description": "Cardo Vacation Rentals — marketing site + embedded design system (Claude Design + Claude Code on one codebase)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "emulators": "firebase emulators:start --only firestore,auth,storage",
    "seed": "tsx scripts/seed-firestore.ts",
    "build:admin": "npm --prefix admin install && npm --prefix admin run build",
    "build:all": "npm run build && npm run build:admin"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "astro": "^7.0.2",
    "firebase-admin": "^14.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.15.0",
    "firebase-tools": "^15.22.4",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}

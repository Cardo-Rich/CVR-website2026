{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "jsx": "react-jsx", "strict": true, "esModuleInterop": true,
    "skipLibCheck": true, "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"], "noEmit": true,
    "baseUrl": ".",
    "paths": { "@shared/*": ["../src/shared/*"] }
  },
  "include": ["src"]
}

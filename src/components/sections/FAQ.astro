---
import Eyebrow from '../ui/Eyebrow.astro';
import { faqs } from '../../data/site';
---

<section class="faq surface-cream2">
  <div class="faq__inner">
    <div class="faq__head">
      <Eyebrow center>Questions, answered</Eyebrow>
      <h2>The owner FAQ.</h2>
    </div>
    <div class="faq__list" data-faq>
      {
        faqs.map((f, i) => (
          <div class:list={['faq__item', i === 0 ? 'is-open' : '']} data-faq-item>
            <button class="faq__q" type="button" aria-expanded={i === 0 ? 'true' : 'false'}>
              <span>{f.q}</span>
              <span class="faq__plus" aria-hidden="true">+</span>
            </button>
            <div class="faq__panel">
              <p class="muted faq__a">{f.a}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--cream-2);
    padding: clamp(64px, 9vw, 120px) 0;
  }
  .faq__inner {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 0 24px;
  }
  .faq__head {
    text-align: center;
    margin-bottom: 44px;
  }
  .faq__head h2 {
    margin: 8px 0 0;
  }
  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq__item {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq__q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--ink);
  }
  .faq__plus {
    color: var(--rose);
    font-size: 1.4rem;
    line-height: 1;
    transition: transform 0.25s var(--ease);
  }
  .faq__item.is-open .faq__plus {
    transform: rotate(45deg);
  }
  .faq__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s var(--ease);
  }
  .faq__item.is-open .faq__panel {
    max-height: 240px;
  }
  .faq__a {
    margin: 0;
    padding: 0 24px 22px;
    font-size: 0.98rem;
  }
</style>

<script>
  // Single-open accordion: opening one row closes the others.
  const list = document.querySelector('[data-faq]');
  list?.querySelectorAll('[data-faq-item]').forEach((item) => {
    const btn = item.querySelector('.faq__q');
    btn?.addEventListener('click', () => {
      const willOpen = !item.classList.contains('is-open');
      list.querySelectorAll('[data-faq-item]').forEach((other) => {
        other.classList.remove('is-open');
        other.querySelector('.faq__q')?.setAttribute('aria-expanded', 'false');
      });
      if (willOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

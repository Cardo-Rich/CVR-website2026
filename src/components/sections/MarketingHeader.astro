---
// Marketing header for secondary public pages. Matches the home nav: a clean
// light-sand bar with the logo and a right-aligned "Menu" drawer.
// `nav` / `cta` are accepted for backwards compatibility but no longer
// rendered — every public page now routes through the shared <Menu /> drawer.
import Menu from './Menu.astro';

interface Props {
  logoHref?: string;
  nav?: { label: string; href: string; active?: boolean }[];
  cta?: { label: string; href: string; floating?: boolean };
}
const { logoHref = '/' } = Astro.props;
---

<header class="site-header" data-header data-screen-label="Header">
  <div class="site-header__inner">
    <a href={logoHref} class="site-header__logo" aria-label="Cardo — home">
      <img src="/assets/logo-horizontal-color.png" alt="Cardo Vacation Rentals" />
    </a>
    <nav class="site-header__nav">
      <a class="nav-cta" href="/owners"><span>Manage My Home</span></a>
      <button type="button" class="menu-btn" data-menu-open aria-expanded="false" aria-controls="site-menu" aria-label="Open menu">
        <span class="menu-btn__bars" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
    </nav>
  </div>
</header>

<Menu />

<script>
  const header = document.querySelector('[data-header]');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

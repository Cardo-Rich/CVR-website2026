---
/**
 * Property/decor photo tile with the brand's gradient fallback + dark scrim,
 * an optional corner meta pill and a display-serif caption.
 * Pass `img` for real photography; otherwise the navy→teal gradient shows.
 */
interface Props {
  img?: string;
  /** Caption shown bottom-left in display serif. */
  tag?: string;
  /** Uppercase pill, top-right. */
  meta?: string;
  /** CSS aspect-ratio, e.g. "4 / 3" or "16 / 9". */
  ratio?: string;
  phA?: string;
  phB?: string;
  class?: string;
}
const {
  img,
  tag,
  meta,
  ratio = '4 / 3',
  phA = '#1b3a52',
  phB = '#2c6e6b',
  class: className = '',
} = Astro.props;

const bg = `radial-gradient(120% 120% at 20% 10%, rgba(255,255,255,0.18), transparent 50%), linear-gradient(135deg, ${phA}, ${phB})`;
---

<div class:list={['phototile', className]} style={`aspect-ratio: ${ratio}; background: ${bg};`}>
  {img && <img class="phototile__bg" src={img} alt={tag || ''} loading="lazy" />}
  <div class="phototile__scrim"></div>
  {meta && <span class="phototile__meta">{meta}</span>}
  {tag && <span class="phototile__tag">{tag}</span>}
  <slot />
</div>

<style>
  .phototile {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: #fff;
    isolation: isolate;
  }
  .phototile__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .phototile__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 35%, rgba(8, 18, 28, 0.66));
    z-index: 1;
  }
  .phototile__meta {
    position: absolute;
    right: 16px;
    top: 16px;
    z-index: 2;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(4px);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
  }
  .phototile__tag {
    position: absolute;
    left: 18px;
    bottom: 16px;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 1.15rem;
  }
</style>

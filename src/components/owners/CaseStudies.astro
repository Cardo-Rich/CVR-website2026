---
import { homePhotos } from '../../data/home';
---

<!-- ===================== DESIGN CASE STUDIES ===================== -->
<section class="cases-feature" id="case-studies" data-screen-label="Design case studies" data-section="case-studies">
  <img class="cases-feature__bg" src={homePhotos['pool']} alt="" />
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:720px">
      <p class="eyebrow">Case studies</p>
      <h2>Home design and project management.</h2>
      <p class="lede">Our in-house design team furnishes and styles your home end to end — sourced, shipped, installed, and photo-ready — so it commands a higher nightly rate from day one. Every home below was designed by Cardo, then went on to beat its market.</p>
    </div>
    <div class="cases__grid" data-cases>
      <button type="button" class="gcase reveal" data-case="falcon">
        <div class="gcase__media"><img src={homePhotos['living-craftsman']} alt="Falcon" loading="lazy" /><span class="gcase__beds">4 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">La Jolla</div><h3 class="gcase__home">Falcon</h3><p class="gcase__hook">An inherited bluff home, fully reimagined and launched in five weeks.</p><div class="gcase__rev">$214,800 <small>annual revenue</small></div><div class="gcase__sub">$589 / night · <span class="lift">+57% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
      <button type="button" class="gcase reveal" data-case="nute">
        <div class="gcase__media"><img src={homePhotos['living-bright']} alt="Nute" loading="lazy" /><span class="gcase__beds">3 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">Pacific Beach</div><h3 class="gcase__home">Nute</h3><p class="gcase__hook">A tired walk-street rental turned light, bright, and fully booked.</p><div class="gcase__rev">$158,300 <small>annual revenue</small></div><div class="gcase__sub">$412 / night · <span class="lift">+44% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
      <button type="button" class="gcase reveal" data-case="twain">
        <div class="gcase__media"><img src={homePhotos['dining']} alt="Twain" loading="lazy" /><span class="gcase__beds">4 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">Del Mar</div><h3 class="gcase__home">Twain</h3><p class="gcase__hook">A craftsman classic styled to own Del Mar's racing season.</p><div class="gcase__rev">$192,500 <small>annual revenue</small></div><div class="gcase__sub">$512 / night · <span class="lift">+48% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
      <button type="button" class="gcase reveal" data-case="sixth">
        <div class="gcase__media"><img src={homePhotos['bedroom-floral']} alt="Sixth" loading="lazy" /><span class="gcase__beds">2 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">Mission Beach</div><h3 class="gcase__home">Sixth</h3><p class="gcase__hook">A compact two-bedroom that punches well above its size.</p><div class="gcase__rev">$128,400 <small>annual revenue</small></div><div class="gcase__sub">$356 / night · <span class="lift">+39% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
      <button type="button" class="gcase reveal" data-case="kane">
        <div class="gcase__media"><img src={homePhotos['gameroom']} alt="Kane" loading="lazy" /><span class="gcase__beds">3 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">Encinitas</div><h3 class="gcase__home">Kane</h3><p class="gcase__hook">A surf-town home with a game room guests book it for.</p><div class="gcase__rev">$168,300 <small>annual revenue</small></div><div class="gcase__sub">$447 / night · <span class="lift">+41% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
      <button type="button" class="gcase reveal" data-case="mt-ainsworth">
        <div class="gcase__media"><img src={homePhotos['pool']} alt="Mt Ainsworth" loading="lazy" /><span class="gcase__beds">5 BR</span></div>
        <div class="gcase__body"><div class="gcase__hood">Coronado</div><h3 class="gcase__home">Mt Ainsworth</h3><p class="gcase__hook">A five-bedroom estate with a resort backyard, top of its market.</p><div class="gcase__rev">$268,900 <small>annual revenue</small></div><div class="gcase__sub">$694 / night · <span class="lift">+61% over market</span></div><span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span></div>
      </button>
    </div>
    <p class="cases__note">Figures are illustrative of recent San Diego performance. Your projection is built from your home's location, size, and finish.</p>
  </div>
</section>

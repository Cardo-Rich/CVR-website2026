---
// The owners "Case studies" grid is built from blog posts flagged
// `showOnOwners` that carry a `caseStudy` block. Each card opens the preview
// modal (home-interactive.js) and links through to the full article at
// /blog/[slug]. The baked markup is the static fallback; the inline layer +
// owners.js re-render it from the live CMS.
import { homePhotos } from '../../data/home';
import { getPublishedArticles } from '../../lib/content/articles';
const all = await getPublishedArticles();
const cases = all.filter((a) => a.showOnOwners && a.caseStudy);
---

<!-- ===================== DESIGN CASE STUDIES ===================== -->
<section class="cases-feature" id="case-studies" data-screen-label="Design case studies" data-section="case-studies" data-cms="owner-cases">
  <img class="cases-feature__bg" src={homePhotos['pool']} alt="" loading="lazy" decoding="async" />
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:720px">
      <p class="eyebrow">Case studies</p>
      <h2>Home design and project management.</h2>
      <p class="lede">Our in-house design team furnishes and styles your home end to end — sourced, shipped, installed, and photo-ready — so it commands a higher nightly rate from day one. Every home below was designed by Cardo, then went on to beat its market.</p>
    </div>
    <div class="cases__grid" data-cases>
      {cases.map((p, i) => {
        const cs = p.caseStudy!;
        const gallery = (cs.gallery && cs.gallery.length) ? cs.gallery : [p.img];
        return (
          <button type="button" class="gcase reveal" hidden={i >= 3} data-case={p.slug} data-full={`/blog/${p.slug}`} data-blurb={p.excerpt} data-gallery={JSON.stringify(gallery)}>
            <div class="gcase__media"><img src={p.img} alt={cs.name} loading="lazy" /><span class="gcase__beds">{cs.beds}</span></div>
            <div class="gcase__body">
              <div class="gcase__hood">{cs.hood}</div>
              <h3 class="gcase__home">{cs.name}</h3>
              <p class="gcase__hook">{p.excerpt}</p>
              <div class="gcase__rev">{cs.revenue} <small>annual revenue</small></div>
              <div class="gcase__sub">{cs.nightly} · <span class="lift">{cs.lift}</span></div>
              <span class="gcase__cta">Preview project <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </div>
          </button>
        );
      })}
    </div>
    <div class="cases__more"><button type="button" class="cases__more-btn" data-cases-more hidden={cases.length <= 3}>Load more case studies</button></div>
    <p class="cases__note">Figures are illustrative of recent San Diego performance. Your projection is built from your home's location, size, and finish.</p>
  </div>
  <!-- Full blog seed for the inline admin editor (admin-only, CMS-empty case). -->
  <script type="application/json" data-blog-seed set:html={JSON.stringify(all)}></script>
</section>

<!-- ===================== CASE PREVIEW MODAL ===================== -->
<div class="cmodal" data-cmodal aria-hidden="true" role="dialog" aria-modal="true">
  <div class="cmodal__scrim" data-cmodal-close></div>
  <div class="cmodal__panel">
    <button type="button" class="cmodal__close" data-cmodal-close aria-label="Close preview"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
    <div class="cmodal__hero"><img data-cm-hero alt="" loading="lazy" decoding="async" /><div class="cmodal__herometa"><div class="cmodal__eyebrow" data-cm-eyebrow></div><h3 class="cmodal__title" data-cm-title></h3></div></div>
    <div class="cmodal__body">
      <div class="cmodal__stats">
        <div class="cmodal__stat is-hero"><div class="v" data-cm-rev></div><div class="l">Annual revenue</div></div>
        <div class="cmodal__stat"><div class="v" data-cm-rate></div><div class="l">Avg / night</div></div>
        <div class="cmodal__stat is-lift"><div class="v" data-cm-lift></div><div class="l">Over market</div></div>
      </div>
      <p class="cmodal__blurb" data-cm-blurb></p>
      <div class="cmodal__thumbs" data-cm-thumbs></div>
      <div class="cmodal__actions">
        <a class="btn" data-cm-contact href="#estimate">Contact us for more information</a>
        <a class="cmodal__seefull" data-cm-full href="#">View full case study →</a>
      </div>
    </div>
  </div>
</div>

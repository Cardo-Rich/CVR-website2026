<!-- ===================== PERFORMANCE ===================== -->
<section class="section-pad perf" id="performance" data-screen-label="Performance">
  <div class="section-wrap">
    <div class="perf__grid">
      <div class="reveal">
        <p class="eyebrow">Cardo vs. the market</p>
        <h2>We don't match the market. We beat it.</h2>
        <p class="lede muted">We out-book the San Diego market on occupancy, month after month — and RevPAR, revenue per available night and the truest measure of performance, tells the same story. Across the 2023 season our homes out-earned the market every single month.</p>
        <div class="perf__stat">
          <span class="perf__statnum" id="perf-avg">+20%</span>
          <span class="perf__statlabel">higher RevPAR than the San&nbsp;Diego market, on average</span>
        </div>
        <div class="perf__legend">
          <span class="perf__leg"><span class="perf__swatch" style="background:var(--rose)"></span>Cardo VR</span>
          <span class="perf__leg"><span class="perf__swatch" style="background:var(--muted)"></span>San Diego market</span>
        </div>
      </div>
      <div class="perf__card reveal">
        <h3>RevPAR by month</h3>
        <p class="perf__sub">San Diego · Mar–Aug 2023 · USD per available night</p>
        <svg class="perf__chart" viewBox="0 0 960 400" role="img" aria-label="Line chart comparing Cardo VR RevPAR against the San Diego market, March through August 2023. Cardo outperforms every month." data-perf-chart></svg>
        <p class="perf__note">Source: Cardo internal RevPAR vs. San Diego market benchmark, 2023.</p>
      </div>
    </div>
    <div class="perf__feats reveal">

---
// ===================== WHAT COMES STANDARD =====================
const items = [
  { h: 'Damage protection', p: 'Coverage on every stay, so an accident is never yours to chase. We handle the claim and the repair and keep the home guest-ready throughout.' },
  { h: 'AI-driven operations', p: 'We build and deploy modern AI tools that run turnovers, pricing, and guest messaging at faster-than-human speed — the operational edge legacy managers can’t match.' },
  { h: 'White-linen program', p: 'We supply and launder crisp, hotel-grade linens and towels — so you never buy sheets again and every guest arrives to a fresh, consistent bed.' },
  { h: 'In-house cleaning & laundry', p: 'We own the entire cleaning and laundry process rather than subcontracting it — the most reliable way to hold quality and protect your reviews.' },
  { h: 'After-hours support', p: 'Real people answer guests at any hour, so a lockout or a midnight question is met before it becomes a one-star review. Your phone stays quiet.' },
  { h: 'Rapid maintenance', p: 'Fast response and vetted local vendors mean small problems get fixed before they grow — usually before the next guest ever arrives.' },
  { h: 'Permits & compliance', p: 'STRO licensing and transient-occupancy tax filed and kept current on your behalf, so your home stays fully compliant without you tracking a deadline.' },
  { h: 'Data-driven pricing', p: 'Rates tuned to live demand to win the high-value nights and beat the market on occupancy — the engine behind the performance in our case studies.' },
  { h: 'Owner portal', p: 'A real-time dashboard for bookings, earnings, and owner stays, plus itemized monthly statements — every dollar visible, whenever you want it.' },
  { h: 'Dedicated property manager', p: 'One named manager who knows your home and your preferences — a single point of contact and a familiar face holding the standard on the ground.' },
  { h: 'Luxury amenities', p: 'Hotel-grade toiletries, coffee, and guest essentials curated and restocked every stay, so your home always feels considered — never bare.' },
  { h: 'Built for investors', p: 'Scaling a portfolio? We help owners underwrite, onboard, and grow new doors across San Diego — one partner as you go from one home to many.' },
];
---

<section class="section-pad surface-cream2" id="care" data-screen-label="Premium care">
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:720px">
      <p class="eyebrow">What comes standard</p>
      <h2>What comes standard with Cardo.</h2>
      <p class="lede muted">The things that protect your home, your guests, and your time are simply part of the service — no upsells, no asterisks.</p>
    </div>
    <div class="bens reveal">
      {items.map((it) => (
        <div class="ben"><h3>{it.h}</h3><p>{it.p}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== TEAM BIO MODAL ===================== -->
<div class="tmodal" data-team-modal aria-hidden="true" role="dialog" aria-modal="true">
  <div class="tmodal__scrim" data-tm-close></div>
  <div class="tmodal__panel">
    <button type="button" class="tmodal__close" data-tm-close aria-label="Close bio"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
    <img class="tmodal__photo" data-tm-photo alt="" loading="lazy" decoding="async" />
    <div class="tmodal__body">
      <div class="tmodal__eyebrow">Leadership</div>
      <h3 class="tmodal__name" data-tm-name></h3>
      <div class="tmodal__role" data-tm-role></div>
      <div class="tmodal__bio" data-tm-bio></div>
    </div>
  </div>
</div>

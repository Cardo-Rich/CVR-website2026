---
import { homePhotos } from '../../data/home';
---

<section class="section-pad" id="concierge" data-screen-label="Concierge">
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:760px">
      <p class="eyebrow">Concierge services</p>
      <h2>Go from trip to all out Vacation with these curated local offerings</h2>
    </div>
    <div class="cphotos" data-cphotos>
      <div class="cphotos__track" data-cphotos-track>
        <figure class="cphoto"><img src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=500&q=80" alt="Airport transfers" loading="lazy" /><figcaption><span class="cphoto__title">Airport transfers</span><span class="cphoto__tag">On request</span></figcaption></figure>
        <figure class="cphoto cphoto--tall"><img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=500&q=80" alt="Private chef and grocery stock" loading="lazy" /><figcaption><span class="cphoto__title">Private chef &amp; grocery stock</span><span class="cphoto__tag">Add-on</span></figcaption></figure>
        <figure class="cphoto"><img src="https://images.unsplash.com/photo-1502933691298-84fc14542831?auto=format&fit=crop&w=500&q=80" alt="Surf and paddle lessons" loading="lazy" /><figcaption><span class="cphoto__title">Surf &amp; paddle lessons</span><span class="cphoto__tag">Booked for you</span></figcaption></figure>
        <figure class="cphoto cphoto--tall"><img src="https://images.unsplash.com/photo-1505228395891-9a51e7e86bf6?auto=format&fit=crop&w=500&q=80" alt="Beach picnics" loading="lazy" /><figcaption><span class="cphoto__title">Beach picnics</span><span class="cphoto__tag">Booked for you</span></figcaption></figure>
        <figure class="cphoto"><img src="https://images.unsplash.com/photo-1534430480872-3498386e7856?auto=format&fit=crop&w=500&q=80" alt="Baby and family gear" loading="lazy" /><figcaption><span class="cphoto__title">Baby &amp; family gear</span><span class="cphoto__tag">On request</span></figcaption></figure>
        <figure class="cphoto"><img src={homePhotos['amenities']} alt="Mid-stay refresh clean" loading="lazy" /><figcaption><span class="cphoto__title">Mid-stay refresh clean</span><span class="cphoto__tag">Add-on</span></figcaption></figure>
      </div>
    </div>
    <div class="reveal" style="margin-top:36px"><a href="/concierge" class="btn btn-blk btn-round">View concierge services</a></div>
  </div>
</section>

---
// Guest reviews — real Google (4.8★, 127) + Airbnb (4.71★, 3,718) data from
// src/data/reviews.ts. Card DOM keeps the class/`data-ct` hooks the carousel
// script (home-interactive.js) and CMS hydration (content-hydrate.js) rely on.
import { reviews, initial, avatarColor } from '../../data/reviews';

const googleReviews = reviews.filter((r) => r.platform === 'google').slice(0, 6);
const airbnbReviews = reviews.filter((r) => r.platform === 'airbnb').slice(0, 6);

const GOOGLE_G = '<svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>';
const AIRBNB_MARK = '<svg viewBox="0 0 32 32" aria-hidden="true"><path fill="#FF385C" d="M16 3c-1.7 0-2.9 1.2-4.1 3.4-2.4 4.5-5 10.2-5.5 11.5-.9 2.3-1.1 3.4-1.1 4.1 0 2.4 1.9 4.3 4.3 4.3 1.5 0 2.7-.6 4.3-2 .9-.8 1.6-1.5 2.1-1.5s1.2.7 2.1 1.5c1.6 1.4 2.8 2 4.3 2 2.4 0 4.3-1.9 4.3-4.3 0-.7-.2-1.8-1.1-4.1-.5-1.3-3.1-7-5.5-11.5C18.9 4.2 17.7 3 16 3zm0 3.2c.5 0 .9.5 1.6 1.8.6 1.1 2.8 5.9 4.9 10.6.6 1.4.8 2.2.8 2.7 0 1.1-.9 2-2 2-.7 0-1.4-.3-2.4-1.1-1.1-.9-2.1-1.7-3.2-1.7s-2.1.8-3.2 1.7c-1 .8-1.7 1.1-2.4 1.1-1.1 0-2-.9-2-2 0-.5.2-1.3.8-2.7 2.1-4.7 4.3-9.5 4.9-10.6.7-1.3 1.1-1.8 1.6-1.8z"/></svg>';
---

<section class="section-pad surface-cream2" id="reviews" data-screen-label="Reviews" data-cms="reviews">
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:680px">
      <p class="eyebrow">Don't take our word for it</p>
      <h2>What guests say about a Cardo stay.</h2>
      <p class="lede muted">Real, verified reviews — straight from Google and Airbnb.</p>
    </div>
    <div class="revtabs reveal" data-revtabs>
      <button type="button" class="revtab is-active" data-revtab="google">
        <Fragment set:html={GOOGLE_G} />
        Google · <span data-ct="g-rating">4.8</span>
      </button>
      <button type="button" class="revtab" data-revtab="airbnb">
        <Fragment set:html={AIRBNB_MARK} />
        Airbnb · <span data-ct="a-rating">4.71</span>
      </button>
    </div>

    <div class="revpanel is-active" data-revpanel="google">
      <div class="greviews" data-greviews>
        <div class="greviews__head">
          <div>
            <div class="greviews__brand">
              <Fragment set:html={GOOGLE_G} />
              <span class="word">Reviews</span>
            </div>
            <div class="greviews__rating"><span class="greviews__score" data-ct="g-rating">4.8</span><span class="greviews__stars">★★★★★</span><span class="greviews__count" data-ct="g-count">127 reviews</span></div>
          </div>
        </div>
        <div class="greviews__viewport">
          <div class="greviews__track">
            {googleReviews.map((r) => (
              <article class="greview">
                <div class="greview__top">
                  <div class="greview__avatar greview__avatar--i" style={`background:${avatarColor(r.name)}`}>{initial(r.name)}<span class="greview__g" set:html={GOOGLE_G} /></div>
                  <div>
                    <div class="greview__name">{r.name}</div>
                    <div class="greview__time">{r.meta || 'Verified Google review'}</div>
                  </div>
                </div>
                <div class="greview__stars">{'★★★★★'.slice(0, r.stars)}</div>
                <p class="greview__text">{r.text}</p>
              </article>
            ))}
          </div>
        </div>
        <div class="greviews__foot">
          <button type="button" class="greviews__arrow" data-grev-prev aria-label="Previous"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></button>
          <div class="greviews__dots"></div>
          <button type="button" class="greviews__arrow" data-grev-next aria-label="Next"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></button>
        </div>
      </div>
    </div>

    <div class="revpanel" data-revpanel="airbnb">
      <div class="abnb">
        <div class="abnb__head">
          <div class="abnb__brand">
            <Fragment set:html={AIRBNB_MARK} />
            <span class="word">Airbnb</span>
          </div>
          <div class="abnb__score"><span class="big" data-ct="a-rating">4.71</span><span class="stars">★★★★★</span><span class="count" data-ct="a-count">3,500+ reviews</span></div>
        </div>
        <div class="abnb__cards">
          {airbnbReviews.map((r) => (
            <article class="abnb__card">
              <div class="abnb__top">
                <span class="abnb__avatar abnb__avatar--i" style={`background:${avatarColor(r.name)}`} aria-hidden="true">{initial(r.name)}</span>
                <div><div class="abnb__name">{r.name}</div><div class="abnb__meta">{r.meta || 'Verified Airbnb stay'}</div></div>
              </div>
              <div class="abnb__stars">{'★★★★★'.slice(0, r.stars)}</div>
              <p class="abnb__text">{r.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
    <slot />
  </div>
</section>

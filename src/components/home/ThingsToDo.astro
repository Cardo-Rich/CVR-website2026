---
// "Explore like a local" cards are built from blog posts flagged `showOnHome`.
// Each card links to the full article at /blog/[slug]; the card fields
// (category kicker, title, blurb, photo, local tip) come from the post. The
// baked markup is the static fallback — the inline layer + home-featured.js
// re-render it from the live CMS.
import { getPublishedArticles } from '../../lib/content/articles';
const all = await getPublishedArticles();
const cards = all.filter((a) => a.showOnHome);
const tipPath = 'M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6-6.3 4.6L8 14 2 9.4h7.6z';
---

<section class="section-pad" id="explore" data-screen-label="Things to do" data-cms="explore">
  <div class="section-wrap">
    <div class="section-head reveal" style="max-width:760px">
      <p class="eyebrow">Explore like a local</p>
      <h2>Craft brews, local eatery favorites, and the best ice cream you've ever had! This is our playground. Let us show you around.</h2>
    </div>
    <div class="todo reveal" data-explore>
      {cards.map((p) => (
        <a class="todo__card" href={`/blog/${p.slug}`} data-explore-slug={p.slug}>
          <img src={p.img} alt={p.title} loading="lazy" />
          <div class="todo__body">
            <div class="todo__kicker">{p.category}</div>
            <h3>{p.title}</h3>
            <p>{p.excerpt}</p>
            {p.localTip && (
              <span class="todo__tip"><svg viewBox="0 0 24 24"><path d={tipPath}/></svg>Local tip: {p.localTip}</span>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="reveal" style="margin-top:36px"><a href="/blog" class="btn btn-blk btn-round">Explore</a></div>
  </div>
  <!-- Full blog seed for the inline admin editor (admin-only, CMS-empty case). -->
  <script type="application/json" data-blog-seed set:html={JSON.stringify(all)}></script>
</section>

---
import { homePhotos } from '../../data/home';
---

<section class="section-pad" id="photos" data-screen-label="Guest photos" data-section="guest-photos">
  <div class="section-wrap">
    <div class="feed__head reveal">
      <div class="feed__handle">
        <div class="feed__avatar"><img src="/assets/logo-horizontal-white-color.png" alt="Cardo" style="width:38px" /></div>
        <div>
          <div class="at">From recent stays</div>
          <div class="sub">Tag <b style="color:var(--rose)">#CardoStays</b> to be featured</div>
        </div>
      </div>
      <a href="#results" class="link-arrow">Book your stay →</a>
    </div>
    <div class="feed__grid reveal">
      <a class="feed__item big" href="#results"><img src={homePhotos['pool']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Coronado</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['living-bright']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Pacific Beach</span></a>
      <a class="feed__item" href="#results"><img src="https://images.unsplash.com/photo-1505228395891-9a51e7e86bf6?auto=format&fit=crop&w=400&q=80" alt="Beach day" loading="lazy" /><span class="feed__loc">Mission Beach</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['bedroom-floral']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Mission Beach</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['dining']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Del Mar</span></a>
      <a class="feed__item" href="#results"><img src="https://images.unsplash.com/photo-1473116763249-2faaef81ccda?auto=format&fit=crop&w=400&q=80" alt="Sunset" loading="lazy" /><span class="feed__loc">Sunset Cliffs</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['living-craftsman']} alt="Guest stay" loading="lazy" /><span class="feed__loc">La Jolla</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['gameroom']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Encinitas</span></a>
      <a class="feed__item" href="#results"><img src="https://images.unsplash.com/photo-1527004013197-933c4bb611b3?auto=format&fit=crop&w=400&q=80" alt="Coastline" loading="lazy" /><span class="feed__loc">La Jolla</span></a>
      <a class="feed__item" href="#results"><img src={homePhotos['amenities']} alt="Guest stay" loading="lazy" /><span class="feed__loc">Carlsbad</span></a>
    </div>
  </div>
</section>

---
import { NAV, SITE } from "../../lib/site-config.js";
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <img src="/assets/cardo-logo-horizontal.svg" alt={SITE.name} width="120" height="30" />
    </a>

    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-cta">
      <a href={SITE.phoneHref} class="header-phone">{SITE.phone}</a>
      <a href="/owners#estimate" class="btn btn-sm">Free estimate</a>
    </div>

    <button class="nav-toggle" aria-label="Open menu" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" data-mobile-nav hidden>
    {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/owners#estimate" class="btn btn-block">Get my free estimate</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 243, 236, 0.82);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.2s var(--ease), border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .site-header.is-scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 6px 24px rgba(16, 34, 52, 0.06);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    height: 72px;
  }
  .brand img { height: 30px; width: auto; }
  .nav {
    display: flex;
    gap: 30px;
    margin-inline: auto;
  }
  .nav a {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink-soft);
    transition: color 0.15s var(--ease);
  }
  .nav a:hover { color: var(--rose); }

  .header-cta { display: flex; align-items: center; gap: 18px; }
  .header-phone { font-weight: 600; font-size: 0.95rem; color: var(--ink); white-space: nowrap; }
  .header-phone:hover { color: var(--rose); }
  .btn-sm { padding: 11px 20px; font-size: 0.92rem; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }
  .nav-toggle span { width: 24px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform 0.2s var(--ease), opacity 0.2s var(--ease); }
  .site-header.nav-open .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-header.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
  .site-header.nav-open .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 12px 24px 24px;
    border-top: 1px solid var(--line);
  }
  .mobile-nav a:not(.btn) {
    padding: 13px 4px;
    font-weight: 500;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--line);
  }
  .mobile-nav .btn { margin-top: 14px; }

  @media (max-width: 940px) {
    .nav, .header-cta { display: none; }
    .nav-toggle { display: flex; }
    .mobile-nav[data-open] { display: flex; }
  }
</style>

<script>
  const header = document.querySelector("[data-site-header]");
  const toggle = document.querySelector("[data-nav-toggle]");
  const mobileNav = document.querySelector("[data-mobile-nav]");
  toggle?.addEventListener("click", () => {
    const open = mobileNav?.toggleAttribute("data-open");
    mobileNav?.toggleAttribute("hidden", !open);
    header?.classList.toggle("nav-open", open);
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
</script>

---
// A styled image tile. Renders an Unsplash (or any) photo over a gradient
// fallback so a failed/slow image still looks intentional. Swap `img` URLs
// for Cardo's own photography anytime — the markup doesn't change.
const {
  img,
  alt = "",
  meta,
  tag,
  grad = ["#1b3a52", "#2c6e6b"],
  w = 900,
  eager = false,
  class: cls = "",
} = Astro.props;

const src = img ? `${img}?auto=format&fit=crop&w=${w}&q=70` : null;
const src2x = img ? `${img}?auto=format&fit=crop&w=${w * 2}&q=60 2x` : null;
---

<div class={`photo ${cls}`} style={`--ph-a:${grad[0]}; --ph-b:${grad[1]};`}>
  {src && (
    <img
      class="photo-bg"
      src={src}
      srcset={src2x}
      alt={alt}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
    />
  )}
  {meta && <span class="photo-meta">{meta}</span>}
  {tag && <span class="photo-tag">{tag}</span>}
  <slot />
</div>

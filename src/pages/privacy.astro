---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';
---

<Base
  title="Privacy Policy | Cardo Vacation Rentals"
  description="How Cardo Vacation Rentals collects, uses, and protects your information — including SMS/text messaging consent."
>
  <MarketingHeader />
  <main>
    <section class="section-pad" style="padding-top:128px" data-screen-label="Privacy policy">
      <div class="section-narrow">
        <p class="eyebrow">Legal</p>
        <h1 style="margin:8px 0 18px">Privacy Policy</h1>
        <p class="lede muted">Placeholder — final privacy policy language is coming. The summary below reflects how we intend to handle your information.</p>
        <h2 style="margin-top:32px">Information we collect</h2>
        <p>When you request an estimate we collect your name, email, phone number, and property address so an account manager can prepare and review your earning estimate.</p>
        <h2 style="margin-top:24px">Text messaging (SMS)</h2>
        <p>If you opt in, we send text messages related to your estimate, account, and appointment reminders. Message &amp; data rates may apply and message frequency varies. Reply STOP to opt out at any time or HELP for help. We do not sell or share your mobile information with third parties for their own marketing, and text-messaging consent is never shared with third parties.</p>
        <h2 style="margin-top:24px">Contact</h2>
        <p>Questions about this policy? Email <a href="mailto:privacy@cardorentals.com">privacy@cardorentals.com</a>.</p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

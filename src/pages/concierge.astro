---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';

const services = [
  { title: 'Airport transfers', tag: 'On request', blurb: 'Private car waiting when you land — no rideshare surge, no waiting curbside.', img: 'https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=700&q=80' },
  { title: 'Private chef & grocery stock', tag: 'Add-on', blurb: 'Arrive to a fully stocked kitchen, or a private chef for the night you want to celebrate.', img: 'https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=700&q=80' },
  { title: 'Surf & paddle lessons', tag: 'Booked for you', blurb: 'Local instructors matched to your level, at the break that suits the day.', img: 'https://images.unsplash.com/photo-1502933691298-84fc14542831?auto=format&fit=crop&w=700&q=80' },
  { title: 'Beach picnics', tag: 'Booked for you', blurb: 'Styled setups on the sand — we handle the gear, the food, and the cleanup.', img: 'https://images.unsplash.com/photo-1505228395891-9a51e7e86bf6?auto=format&fit=crop&w=700&q=80' },
  { title: 'Baby & family gear', tag: 'On request', blurb: 'Cribs, high chairs, strollers, and beach toys delivered before you arrive.', img: 'https://images.unsplash.com/photo-1534430480872-3498386e7856?auto=format&fit=crop&w=700&q=80' },
  { title: 'Mid-stay refresh clean', tag: 'Add-on', blurb: 'A discreet turnover mid-trip so the home feels brand new all over again.', img: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?auto=format&fit=crop&w=700&q=80' },
];
---

<Base
  title="Concierge Services | Cardo Vacation Rentals"
  description="Turn a trip into a vacation with Cardo's San Diego concierge — airport transfers, private chefs, surf lessons, beach picnics, and family gear on request."
  image="/assets/og/og-concierge.jpg"
  imageAlt="Cardo guest concierge — five-star stays across San Diego"
>
  <MarketingHeader />

  <main>
    <section class="phero" data-screen-label="Concierge hero">
      <img class="phero__bg" src="https://images.unsplash.com/photo-1505228395891-9a51e7e86bf6?auto=format&fit=crop&w=1600&q=80" alt="" />
      <div class="phero__overlay"></div>
      <div class="phero__inner narrow">
        <p class="eyebrow">Concierge services</p>
        <h1>Make it a vacation worth remembering.</h1>
        <p>From the moment you land to your last morning on the sand, our local team handles the details so you don’t have to. Placeholder copy — services and pricing coming soon.</p>
        <a class="btn btn-lg btn-blk btn-round" href="/#results">Find your home</a>
      </div>
    </section>

    <section class="section-pad" data-screen-label="Concierge services list">
      <div class="section-wrap">
        <div class="section-head reveal" style="max-width:720px">
          <p class="eyebrow">Curated local offerings</p>
          <h2>Everything you could want, arranged for you.</h2>
        </div>
        <div class="cases__grid">
          {services.map((s) => (
            <div class="case reveal">
              <div class="case__media"><img src={s.img} alt={s.title} loading="lazy" /><span class="case__beds">{s.tag}</span></div>
              <div class="case__body">
                <h3 class="case__home">{s.title}</h3>
                <p class="case__hook">{s.blurb}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="cta" data-screen-label="CTA">
      <div class="cta__inner reveal">
        <p class="eyebrow">At your service</p>
        <h2>Tell us what would make the trip.</h2>
        <p>Book any service before you arrive, or ask our concierge once you’re here — we’ll make it happen.</p>
        <a class="btn btn-lg" href="/#results">Browse homes</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  import '../scripts/reveal.js';
</script>

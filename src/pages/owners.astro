---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';
import OwnerHero from '../components/owners/OwnerHero.astro';
import ByTheNumbers from '../components/owners/ByTheNumbers.astro';
import Partners from '../components/owners/Partners.astro';
import AirbnbProof from '../components/owners/AirbnbProof.astro';
import Reviews from '../components/home/Reviews.astro';
import Performance from '../components/owners/Performance.astro';
import CaseStudies from '../components/owners/CaseStudies.astro';
import Marketing from '../components/owners/Marketing.astro';
import Assurance from '../components/owners/Assurance.astro';
import Investors from '../components/owners/Investors.astro';
import Compare from '../components/owners/Compare.astro';
import Team from '../components/owners/Team.astro';
import Testimonials from '../components/owners/Testimonials.astro';
import Founder from '../components/owners/Founder.astro';
import Process from '../components/owners/Process.astro';
import Faq from '../components/owners/Faq.astro';
import TeamModal from '../components/owners/TeamModal.astro';
import CaseModal from '../components/owners/CaseModal.astro';
import '../styles/home.css';
import '../styles/owners.css';
---

<Base title="Luxury Vacation Rental Management | Cardo Vacation Rentals" description="Luxury San Diego vacation rental management — a free earning estimate verified by a personal account manager, above-market revenue, and full-service marketing. 5-star Superhost since 2013.">
  <MarketingHeader />
  <main>
    <OwnerHero />
    <Performance />
    <Assurance />
    <CaseStudies />
    <Compare />
    <Marketing />
    <ByTheNumbers />
    <Partners />
    <Reviews><AirbnbProof /></Reviews>
    <Testimonials />
    <Team />
    <Founder />
    <Investors />
    <Process />
    <Faq />
  </main>
  <a class="btn estimate-fab" data-estimate-fab href="#estimate">Schedule a consultation</a>
  <aside class="estimate-card" data-estimate-fab>
    <h3>Surpass the competition today</h3>
    <p class="estimate-card__sub">Cardo-designed homes outperform their market by up to 61%</p>
    <a href="#estimate" class="btn estimate-card__btn">Schedule a consultation</a>
  </aside>
  <TeamModal />
  <CaseModal />
  <Footer />
</Base>

<script>
  import '../scripts/owners.js';
  import '../scripts/sections.js';
  import '../scripts/home-interactive.js';
  import '../scripts/team-modal.js';
  import '../scripts/guest.js';
</script>

---
import Layout from "../layouts/Layout.astro";
import Photo from "../components/site/Photo.astro";
import { SITE, GALLERY, DESIGN_PROCESS, DESIGN_SCOPE } from "../lib/site-config.js";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Home Designs by Cardo",
  serviceType: "Vacation rental interior design & furnishing",
  provider: { "@type": "LodgingBusiness", name: SITE.name },
  areaServed: "San Diego County, California",
  description:
    "In-house interior design and furnishing for San Diego short-term rentals — styled and staged to photograph beautifully and command higher nightly rates.",
};
---

<Layout
  title="Home Designs by Cardo — Interior Design for Rentals"
  description="Home Designs by Cardo is our in-house interior design and furnishing service for San Diego short-term rentals. Styled to photograph beautifully and earn more. Exclusive to managed homes."
  path="/design"
  schema={[serviceSchema]}
>
  <!-- ===================== HERO ===================== -->
  <section class="d-hero">
    <div class="container d-hero-inner">
      <div class="d-hero-copy" data-reveal>
        <span class="eyebrow">Home Designs by Cardo</span>
        <h1>Design that pays for itself.</h1>
        <p class="lede">
          Our in-house design team turns your home into a listing guests can't scroll past —
          styled to photograph beautifully, live well, and command a higher nightly rate.
        </p>
        <div class="d-hero-cta">
          <a href="/owners#estimate" class="btn btn-lg">Get a furnishing estimate</a>
          <a href="#process" class="btn btn-ghost btn-lg">See the process</a>
        </div>
        <p class="d-exclusive">Design services are exclusive to Cardo-managed homes.</p>
      </div>
      <Photo
        class="d-hero-photo"
        img="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85"
        alt="A Cardo-styled coastal primary suite in San Diego"
        meta="Styling"
        tag="Coastal primary suite"
        grad={["#1f3a52", "#2c6e6b"]}
        w={760}
        eager={true}
      />
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">Selected work</span>
        <h2 class="center">A look at our styling.</h2>
      </div>
      <div class="d-gallery">
        {GALLERY.map((g) => (
          <Photo
            class={`d-tile span-${g.span}`}
            img={g.img}
            alt={`${g.tag} — Home Designs by Cardo`}
            meta={g.meta}
            tag={g.tag}
            grad={g.grad}
            w={g.span === 2 ? 900 : 520}
          />
        ))}
      </div>
      <p class="center muted d-gallery-note">Portfolio shots are samples — your full project gallery goes here.</p>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="section surface-cream2" id="process">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">How it works</span>
        <h2 class="center">From photos to fully styled in 2–4 weeks.</h2>
      </div>
      <div class="grid cols-4 d-process">
        {DESIGN_PROCESS.map((s) => (
          <article class="d-step" data-reveal>
            <span class="d-step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p class="muted">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== SCOPE ===================== -->
  <section class="section">
    <div class="container d-scope">
      <div class="d-scope-copy" data-reveal>
        <span class="eyebrow">What's included</span>
        <h2>Your decorator handles all of it.</h2>
        <p class="lede">
          One designer manages style, sourcing, building, and staging end to end — with
          receipts and accurate accounting the whole way through. Labor and materials are
          billed transparently to your agreed budget.
        </p>
        <a href="/owners#estimate" class="btn btn-lg">Start with a free estimate</a>
      </div>
      <ul class="d-scope-list" data-reveal>
        {DESIGN_SCOPE.map((i) => <li>{i}</li>)}
      </ul>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="section surface-ink">
    <div class="container center d-final" data-reveal>
      <h2>Ready to make your home unforgettable?</h2>
      <p class="lede mx-auto" style="max-width: 48ch; color: rgba(248,243,236,0.78);">
        Send a few photos and we'll come back with a furnishing estimate and decorator's fee.
      </p>
      <a href="/owners#estimate" class="btn btn-lg">Get my furnishing estimate</a>
    </div>
  </section>
</Layout>

<style>
  .d-hero {
    background:
      radial-gradient(70% 110% at 90% -10%, rgba(237, 60, 120, 0.08), transparent 55%),
      linear-gradient(180deg, var(--cream), var(--cream-2));
    padding: clamp(48px, 7vw, 92px) 0;
  }
  .d-hero-inner { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 56px; align-items: center; }
  .d-hero-copy .lede { max-width: 50ch; margin-top: 16px; }
  .d-hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin: 28px 0 18px; }
  .d-exclusive { font-size: 0.88rem; color: var(--muted); font-style: italic; margin: 0; }
  .d-hero-photo { aspect-ratio: 4 / 5; box-shadow: var(--shadow-lg); }

  .section-head { margin-bottom: 48px; }

  .d-gallery { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 230px; gap: 18px; }
  .d-tile.span-2 { grid-column: span 2; }
  .d-gallery-note { margin-top: 28px; font-size: 0.85rem; }
  @media (max-width: 860px) { .d-gallery { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .d-gallery { grid-template-columns: 1fr; } .d-tile.span-2 { grid-column: span 1; } }

  .d-step-num { font-family: var(--font-display); font-size: 2.2rem; color: var(--gold); display: block; margin-bottom: 6px; }
  .d-step h3 { font-size: 1.2rem; }

  .d-scope { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 52px; align-items: center; }
  .d-scope-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px 28px; }
  .d-scope-list li { position: relative; padding-left: 30px; color: var(--ink-soft); }
  .d-scope-list li::before {
    content: "✓"; position: absolute; left: 0; top: 1px;
    width: 21px; height: 21px; border-radius: 50%;
    background: rgba(237, 60, 120, 0.12); color: var(--rose);
    display: grid; place-items: center; font-size: 0.75rem; font-weight: 700;
  }

  .d-final h2 { max-width: 18ch; margin-inline: auto; }
  .d-final .btn { margin-top: 12px; }

  @media (max-width: 960px) {
    .d-hero-inner, .d-scope { grid-template-columns: 1fr; gap: 38px; }
    .d-hero-photo { max-width: 440px; }
  }
  @media (max-width: 540px) { .d-scope-list { grid-template-columns: 1fr; } }
</style>

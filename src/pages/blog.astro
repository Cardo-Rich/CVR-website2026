---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';
import { categories } from '../data/blog';
import { getPublishedArticles } from '../lib/content/articles';

const articles = await getPublishedArticles();
const featured = articles.find((a) => a.featured);
const rest = articles.filter((a) => !a.featured);

const nav = [
  { label: 'For Owners', href: '/owners' },
  { label: 'Design', href: '/home-designs' },
  { label: 'Case studies', href: '/home-designs#case-studies' },
  { label: 'Blog', href: '/blog', active: true },
];
const cta = { label: 'Free estimate', href: '/owners#estimate' };
---

<Base
  title="The Cardo Journal — Owner insights for San Diego STR"
  description="Revenue, design, compliance, and neighborhood insight for San Diego vacation rental owners — from the Cardo team."
>
  <MarketingHeader {nav} {cta} />

  <main>
    <!-- TOP -->
    <section class="blog-top" data-screen-label="Blog header">
      <div class="section-wrap">
        <div class="blog-top__head">
          <p class="eyebrow">The Cardo Journal</p>
          <h1>Insight for San Diego owners.</h1>
          <p>Revenue, design, compliance, and neighborhood know-how — the things that actually move what your home earns.</p>
        </div>
        <div class="cats">
          {categories.map((c, i) => (
            <span class={i === 0 ? 'cat is-active' : 'cat'}>{c}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURED -->
    {featured && (
      <section class="section-pad-sm" data-screen-label="Featured post" style="padding-top:clamp(32px,5vw,56px)">
        <div class="section-wrap">
          <a class="feat reveal" href={`/blog/${featured.slug}`} data-blog-featured data-blog-slug={featured.slug}>
            <div class="feat__media"><img src={featured.img} alt={featured.title} loading="lazy" /></div>
            <div class="feat__body">
              <div class="post-meta"><span class="post-cat">{featured.category}</span><span>{featured.readTime}</span><span>{featured.dateShort}</span></div>
              <h2>{featured.title}</h2>
              <p>{featured.excerpt}</p>
              <span class="link-arrow">Read the analysis →</span>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- POSTS -->
    <section class="section-pad-sm" data-screen-label="Posts" style="padding-top:0" data-cms="blog">
      <div class="section-wrap">
        <div class="posts" data-blog-grid>
          {rest.map((p) => (
            <a class="post reveal" href={`/blog/${p.slug}`} data-blog-slug={p.slug}>
              <div class="post__media"><img src={p.img} alt={p.title} loading="lazy" /></div>
              <div class="post__body">
                <div class="post-meta"><span class="post-cat">{p.category}</span><span>{p.readTime}</span></div>
                <h3>{p.title}</h3>
                <p>{p.excerpt}</p>
                <span class="link-arrow">Read →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- DESIGN CASE STUDIES (link to Design page) -->
    <section class="section-pad-sm surface-cream2" data-screen-label="Design case studies">
      <div class="section-narrow">
        <div class="cta__inner" style="padding:0;text-align:center">
          <p class="eyebrow" style="justify-content:center">Design case studies</p>
          <h2 style="margin:8px 0 14px">See the homes we designed beat their market.</h2>
          <p class="lede muted" style="margin:0 auto 24px;max-width:560px">San Diego homes furnished and styled end to end by Cardo — each with the full story, the scope of work, and what it returned.</p>
          <a href="/home-designs#case-studies" class="btn btn-lg">Explore the design case studies</a>
        </div>
      </div>
    </section>

    <!-- CASE-STUDY LIBRARY (CMS-driven; stays hidden until content loads) -->
    <section class="caselib" id="case-library" data-caselib hidden data-screen-label="Case-study library">
      <div class="section-wrap">
        <div class="section-head" style="max-width:680px">
          <p class="eyebrow">The case-study library</p>
          <h2>Every home, every result.</h2>
        </div>
        <div class="caselib__grid" data-caselib-grid></div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="news" data-screen-label="Newsletter">
      <div class="news__inner reveal">
        <div>
          <p class="eyebrow">Owner notes</p>
          <h2>San Diego STR insight, monthly.</h2>
          <p>Pricing trends, design ideas, and compliance updates. No noise — unsubscribe anytime.</p>
        </div>
        <form class="news__form" onsubmit="this.querySelector('input').value='Thanks — you’re subscribed.';this.querySelector('input').disabled=true;return false;">
          <input type="email" placeholder="you@email.com" aria-label="Email" required />
          <button class="btn" type="submit">Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
  <!-- Full seed data for the inline admin editor (admin-only, CMS-empty case). -->
  <script type="application/json" data-blog-seed set:html={JSON.stringify(articles)}></script>
</Base>

<script>
  import '../scripts/blog.js';

  (function () {
    var cats = document.querySelectorAll('.cat');
    cats.forEach(function (c) {
      c.addEventListener('click', function () {
        cats.forEach(function (x) { x.classList.remove('is-active'); });
        c.classList.add('is-active');
      });
    });
  })();

  // Case-study library — the full CMS list (featured or not). Hidden until
  // /api/content responds, so the page is unchanged pre-deploy/offline.
  (function () {
    var section = document.querySelector('[data-caselib]');
    var grid = document.querySelector('[data-caselib-grid]');
    if (!section || !grid) return;
    var PAGES = ['falcon', 'nute', 'twain', 'sixth', 'kane', 'mt-ainsworth']; // have static detail pages
    fetch('/api/content', { headers: { Accept: 'application/json' } })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (d) {
        // CMS section switch: case studies hidden site-wide → keep the library hidden too.
        if (d && d.sections && d.sections['case-studies'] === false) return;
        var items = (d && d.caseStudies) || [];
        if (!items.length) return;
        items.forEach(function (cs) {
          if (!cs || !cs.id) return;
          var hasPage = PAGES.indexOf(cs.id) !== -1;
          var el = document.createElement(hasPage ? 'a' : 'div');
          el.className = 'caselib__card';
          if (hasPage) el.setAttribute('href', '/case-studies/' + cs.id);
          var img = document.createElement('img');
          img.src = cs.img || '/assets/photos/designs-' + (hasPage ? { falcon: 'living-craftsman', nute: 'living-bright', twain: 'dining', sixth: 'bedroom-floral', kane: 'gameroom', 'mt-ainsworth': 'pool' }[cs.id] : 'pool') + '.jpg';
          img.alt = cs.name; img.loading = 'lazy';
          el.appendChild(img);
          var body = document.createElement('div'); body.className = 'caselib__body';
          function add(tag, cls, text) { var n = document.createElement(tag); n.className = cls; n.textContent = text || ''; body.appendChild(n); }
          add('div', 'caselib__hood', cs.hood + (cs.beds ? ' · ' + cs.beds : ''));
          add('h3', 'caselib__name', cs.name);
          add('p', 'caselib__hook', cs.hook);
          var stats = document.createElement('div'); stats.className = 'caselib__stats';
          stats.innerHTML = '<b></b><span class="lift"></span>';
          stats.querySelector('b').textContent = cs.revenue || '';
          stats.querySelector('.lift').textContent = cs.lift || '';
          body.appendChild(stats);
          el.appendChild(body);
          grid.appendChild(el);
        });
        section.hidden = false;
      })
      .catch(function () { /* endpoint unavailable — section stays hidden */ });
  })();

  import '../scripts/reveal.js';
</script>

<style is:global>
  /* Global (not scoped): these cards are created by client-side JS, which
     never receives Astro's scoping attribute. */
  .caselib { padding: clamp(48px, 7vw, 88px) 0; background: var(--paper); }
  .caselib__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 36px; }
  .caselib__card { display: block; border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; background: var(--paper); box-shadow: var(--shadow-sm); color: inherit; transition: transform var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease); }
  .caselib__card[href]:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .caselib__card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
  .caselib__body { padding: 18px 20px 20px; }
  .caselib__hood { font-size: .74rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); }
  .caselib__name { font-size: 1.3rem; margin: 6px 0 8px; }
  .caselib__hook { font-size: .92rem; color: var(--muted); line-height: 1.5; margin: 0 0 12px; }
  .caselib__stats { display: flex; align-items: baseline; gap: 12px; padding-top: 12px; border-top: 1px solid var(--line); }
  .caselib__stats b { font-family: var(--font-display); font-weight: 500; font-size: 1.3rem; }
  .caselib__stats .lift { color: var(--success); font-weight: 600; font-size: .9rem; }
  @media (max-width: 900px) { .caselib__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .caselib__grid { grid-template-columns: 1fr; } }
</style>

<style>
  .blog-top { padding: 128px 0 0; }
  .blog-top__head { max-width: var(--container-narrow); }
  .blog-top h1 { font-size: clamp(2.4rem,4.6vw,3.6rem); margin: 12px 0 16px; }
  .blog-top p { font-size: 1.18rem; color: var(--ink-soft); max-width: 600px; }
  .cats { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 30px; }
  .cat { font-size: .85rem; font-weight: 600; color: var(--ink-soft); border: 1px solid var(--line-strong); border-radius: var(--radius-pill); padding: 9px 18px; transition: all var(--dur-fast) var(--ease); cursor: pointer; }
  .cat:hover, .cat.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }

  /* Featured */
  .feat { display: grid; grid-template-columns: 1.15fr 1fr; gap: 40px; align-items: center; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  .feat:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .feat__media { aspect-ratio: 16/11; }
  .feat__media img { width: 100%; height: 100%; object-fit: cover; }
  .feat__body { padding: 16px 40px 16px 0; }
  .feat__body h2 { font-size: clamp(1.6rem,2.6vw,2.2rem); margin: 10px 0 14px; }
  .feat__body p { color: var(--muted); margin: 0 0 20px; }
  @media (max-width: 820px) { .feat { grid-template-columns: 1fr; } .feat__media { aspect-ratio: 16/9; } .feat__body { padding: 0 28px 30px; } }

  .post-meta { display: flex; gap: 14px; align-items: center; font-size: .82rem; color: var(--muted); }
  .post-cat { color: var(--rose); font-weight: 600; letter-spacing: .04em; text-transform: uppercase; font-size: .76rem; }

  /* Grid */
  .posts { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }
  .post { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  .post:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .post__media { aspect-ratio: 16/10; }
  .post__media img { width: 100%; height: 100%; object-fit: cover; }
  .post__body { padding: 24px; display: flex; flex-direction: column; flex: 1; }
  .post__body h3 { font-size: 1.28rem; margin: 10px 0 10px; }
  .post__body p { color: var(--muted); font-size: .95rem; margin: 0 0 18px; flex: 1; }
  @media (max-width: 900px) { .posts { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .posts { grid-template-columns: 1fr; } }

  /* Newsletter */
  .news { background: var(--cream-2); }
  .news__inner { max-width: var(--container-narrow); margin: 0 auto; padding: clamp(48px,7vw,80px) 24px; display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; align-items: center; }
  .news h2 { margin: 8px 0 10px; }
  .news p { color: var(--muted); margin: 0; }
  .news__form { display: flex; gap: 10px; }
  .news__form input { flex: 1; font-family: var(--font-body); font-size: .98rem; padding: 14px 16px; border: 1px solid var(--line-strong); border-radius: var(--radius-pill); background: #fff; outline: none; }
  .news__form input:focus { border-color: var(--rose); box-shadow: 0 0 0 3px var(--accent-soft); }
  @media (max-width: 720px) { .news__inner { grid-template-columns: 1fr; gap: 22px; } }
</style>

---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';
---

<Base
  title="Terms of Service | Cardo Vacation Rentals"
  description="The terms that govern your use of Cardo Vacation Rentals' website and services."
>
  <MarketingHeader />
  <main>
    <section class="section-pad" style="padding-top:128px" data-screen-label="Terms of service">
      <div class="section-narrow">
        <p class="eyebrow">Legal</p>
        <h1 style="margin:8px 0 18px">Terms of Service</h1>
        <p class="lede muted">Placeholder — final terms of service language is coming. The summary below outlines the basics.</p>
        <h2 style="margin-top:32px">Using our site</h2>
        <p>By submitting an estimate request you confirm the information you provide is accurate and that you are authorized to request management services for the property.</p>
        <h2 style="margin-top:24px">Communications</h2>
        <p>By providing your phone number and opting in, you agree to receive calls and text messages from Cardo about your estimate and account. See our <a href="/privacy">Privacy Policy</a> for details, including how to opt out.</p>
        <h2 style="margin-top:24px">Contact</h2>
        <p>Questions about these terms? Email <a href="mailto:hello@cardorentals.com">hello@cardorentals.com</a>.</p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

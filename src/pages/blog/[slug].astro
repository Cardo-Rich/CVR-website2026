---
import Base from '../../layouts/Base.astro';
import MarketingHeader from '../../components/sections/MarketingHeader.astro';
import Footer from '../../components/sections/Footer.astro';
import { articles } from '../../data/blog';

export function getStaticPaths() {
  return articles.map((a, i) => ({
    params: { slug: a.slug },
    props: { a, related: [articles[(i+1)%articles.length], articles[(i+2)%articles.length], articles[(i+3)%articles.length]] },
  }));
}
const { a, related } = Astro.props;
const nav = [
  { label: 'For Owners', href: '/owners' },
  { label: 'Design', href: '/home-designs' },
  { label: 'Case studies', href: '/home-designs#case-studies' },
  { label: 'Blog', href: '/blog', active: true },
];
const cta = { label: 'Free estimate', href: '/owners#estimate' };
---

<Base title={a.seo.title} description={a.seo.description}>
  <MarketingHeader {nav} {cta} />

  <main>
    <article data-screen-label="Article">
      <div class="art-head">
        <a href="/blog" class="link-arrow" style="border:0;font-size:.9rem;color:var(--muted);margin-bottom:18px">← The Cardo Journal</a>
        <div class="post-cat">{a.category}</div>
        <h1>{a.title}</h1>
        <div class="art-byline">
          <div class="art-avatar">{a.author.initials}</div>
          <div>
            <div class="who">{a.author.name}</div>
            <div class="meta">{a.dateFull} · {a.readTime}</div>
          </div>
        </div>
      </div>

      <div class="art-hero">
        <figure>
          <img src={a.img} alt={a.title} />
          <figcaption>{a.heroCaption}</figcaption>
        </figure>
      </div>

      <div class="prose" set:html={a.bodyHtml} />

      <div class="art-cta">
        <div class="art-cta__box">
          <h3>See your home’s number.</h3>
          <p>A data-backed revenue projection for your San Diego market — no obligation.</p>
          <a href="/owners#estimate" class="btn btn-lg">Get my free estimate</a>
        </div>
      </div>
    </article>

    <!-- RELATED -->
    <section class="related" data-screen-label="Related">
      <div class="related__inner">
        <div class="section-head" style="margin-bottom:0">
          <p class="eyebrow">Keep reading</p>
          <h2>More from the Journal.</h2>
        </div>
        <div class="related__grid">
          {related.map((r) => (
            <a class="rpost" href={`/blog/${r.slug}`}>
              <img src={r.img} alt="" loading="lazy" />
              <div class="rpost__b">
                <span class="post-cat" style="color:var(--rose);font-size:.74rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase">{r.category}</span>
                <h4>{r.title}</h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  import '../../scripts/reveal.js';
</script>

<style>
  .art-head { max-width: var(--container-narrow); margin: 0 auto; padding: 124px 24px 0; }
  .art-head .post-cat { color: var(--rose); font-weight: 600; letter-spacing: .06em; text-transform: uppercase; font-size: .78rem; }
  .art-head h1 { font-size: clamp(2.2rem,4.4vw,3.4rem); margin: 14px 0 20px; }
  .art-byline { display: flex; align-items: center; gap: 14px; padding: 18px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .art-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--ink); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 1.05rem; }
  .art-byline .who { font-weight: 600; color: var(--ink); font-size: .95rem; }
  .art-byline .meta { font-size: .85rem; color: var(--muted); }

  .art-hero { max-width: var(--container); margin: 36px auto 0; padding: 0 24px; }
  .art-hero figure { margin: 0; }
  .art-hero img { width: 100%; aspect-ratio: 16/8; object-fit: cover; border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
  .art-hero figcaption { font-size: .82rem; color: var(--muted); margin-top: 12px; text-align: center; }

  .prose { max-width: 720px; margin: 0 auto; padding: clamp(40px,6vw,64px) 24px clamp(40px,6vw,64px); }
  .prose .lede { font-size: 1.32rem; line-height: 1.5; color: var(--ink); font-family: var(--font-display); font-weight: 400; margin-bottom: 28px; }
  .prose p { font-size: 1.12rem; line-height: 1.72; color: var(--ink-soft); margin: 0 0 1.3em; }
  .prose h2 { font-size: 1.7rem; margin: 1.6em 0 .5em; }
  .prose h3 { font-size: 1.3rem; margin: 1.4em 0 .4em; }
  .prose ul { margin: 0 0 1.4em; padding: 0; list-style: none; }
  .prose ul li { position: relative; padding-left: 28px; margin-bottom: 12px; font-size: 1.08rem; line-height: 1.6; color: var(--ink-soft); }
  .prose ul li::before { content: ""; position: absolute; left: 4px; top: 11px; width: 7px; height: 7px; border-radius: 50%; background: var(--rose); }
  .prose blockquote { margin: 1.6em 0; padding: 4px 0 4px 28px; border-left: 3px solid var(--rose); font-family: var(--font-display); font-size: 1.5rem; line-height: 1.35; color: var(--ink); }
  .prose a.inline { color: var(--rose); border-bottom: 1px solid var(--accent-soft); }

  .callout { background: var(--cream-2); border-radius: var(--radius-lg); padding: 28px 30px; margin: 1.8em 0; }
  .callout .eyebrow { margin-bottom: 10px; }
  .callout p { margin: 0; font-size: 1.05rem; color: var(--ink-soft); }

  .art-cta { max-width: 720px; margin: 0 auto 0; padding: 0 24px clamp(48px,7vw,80px); }
  .art-cta__box { background: var(--ink); border-radius: var(--radius-lg); padding: clamp(32px,5vw,48px); text-align: center; }
  .art-cta__box h3 { color: #fff; font-size: 1.7rem; margin: 0 0 10px; }
  .art-cta__box p { color: rgba(248,243,236,.82); margin: 0 0 22px; }

  .related { background: var(--cream-2); }
  .related__inner { max-width: var(--container); margin: 0 auto; padding: clamp(56px,8vw,88px) 24px; }
  .related__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; margin-top: 32px; }
  .rpost { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease); }
  .rpost:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .rpost img { width: 100%; aspect-ratio: 16/10; object-fit: cover; }
  .rpost__b { padding: 22px; }
  .rpost__b h4 { font-family: var(--font-display); font-weight: 500; font-size: 1.18rem; margin: 8px 0 0; color: var(--ink); }
  @media (max-width: 820px) { .related__grid { grid-template-columns: 1fr; max-width: 460px; } }
</style>

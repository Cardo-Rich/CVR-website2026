---
import Layout from "../../layouts/Layout.astro";
import Photo from "../../components/site/Photo.astro";
import { getPublishedPosts, formatDate, readingTime } from "../../lib/blog.js";
import { SITE } from "../../lib/site-config.js";

const posts = await getPublishedPosts();
const [featured, ...rest] = posts;

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: `${SITE.name} Blog`,
  url: new URL("/blog", SITE.url).href,
  description: "Owner guides on San Diego short-term rental earnings, rules, design, and management.",
};
const grad = (s) => (s ? s.split(",") : ["#1b3a52", "#2c6e6b"]);
---

<Layout
  title="Blog — San Diego Short-Term Rental Insights"
  description="Owner guides on San Diego short-term rental earnings, STR rules, design, and management — from Cardo, trusted with San Diego homes since 2013."
  path="/blog"
  schema={[blogSchema]}
>
  <section class="blog-hero">
    <div class="container">
      <span class="eyebrow">The Cardo Journal</span>
      <h1>San Diego rental insights for owners.</h1>
      <p class="lede mx-auto">
        Straight talk on earnings, regulations, design, and getting more from your home —
        from the team that's managed San Diego rentals since 2013.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <div class="blog-empty card">
          <h3>New articles are on the way.</h3>
          <p class="muted">We're publishing owner guides shortly. In the meantime, get a free estimate for your home.</p>
          <a href="/owners#estimate" class="btn">Get your free estimate</a>
        </div>
      ) : (
        <>
          {featured && (
            <a class="featured" href={`/blog/${featured.slug}`} data-reveal>
              <Photo
                class="featured-photo"
                img={featured.cover_image}
                alt={featured.title}
                grad={grad(featured.cover_grad)}
                w={900}
                eager={true}
              />
              <div class="featured-body">
                <span class="post-kicker">Latest · {formatDate(featured.published_at)} · {readingTime(featured.body)} min read</span>
                <h2>{featured.title}</h2>
                <p class="muted">{featured.excerpt}</p>
                <span class="link-arrow">Read article →</span>
              </div>
            </a>
          )}

          {rest.length > 0 && (
            <div class="grid cols-3 post-grid">
              {rest.map((p) => (
                <a class="post-card card" href={`/blog/${p.slug}`} data-reveal>
                  <Photo class="post-photo" img={p.cover_image} alt={p.title} grad={grad(p.cover_grad)} w={520} />
                  <div class="post-card-body">
                    <span class="post-kicker">{formatDate(p.published_at)} · {readingTime(p.body)} min read</span>
                    <h3>{p.title}</h3>
                    <p class="muted">{p.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          )}
        </>
      )}
    </div>
  </section>

  <section class="section-sm surface-cream2">
    <div class="container center">
      <h2>Want a number for your specific home?</h2>
      <p class="lede mx-auto" style="max-width: 46ch;">Get a free, data-backed revenue estimate for your San Diego property.</p>
      <a href="/owners#estimate" class="btn btn-lg">Get your free estimate</a>
    </div>
  </section>
</Layout>

<style>
  .blog-hero {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
    padding: clamp(56px, 8vw, 104px) 0 clamp(40px, 5vw, 64px);
    text-align: center;
  }
  .blog-hero .lede { max-width: 56ch; }

  .blog-empty { text-align: center; padding: 56px 32px; }
  .blog-empty .btn { margin-top: 12px; }

  .featured {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 64px;
  }
  .featured-photo { aspect-ratio: 16 / 11; box-shadow: var(--shadow-md); }
  .featured-body h2 { font-size: clamp(1.6rem, 3vw, 2.3rem); margin: 10px 0 12px; }

  .post-kicker { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.04em; color: var(--rose); text-transform: uppercase; }

  .post-grid { gap: 30px; }
  .post-card { overflow: hidden; display: flex; flex-direction: column; transition: transform 0.18s var(--ease), box-shadow 0.18s var(--ease); }
  .post-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .post-photo { aspect-ratio: 16 / 10; border-radius: 0; }
  .post-card-body { padding: 22px 22px 26px; display: flex; flex-direction: column; gap: 8px; }
  .post-card-body h3 { font-size: 1.25rem; margin: 2px 0; }

  @media (max-width: 820px) {
    .featured { grid-template-columns: 1fr; gap: 24px; }
  }
</style>

---
import Base from '../layouts/Base.astro';
import MarketingHeader from '../components/sections/MarketingHeader.astro';
import Footer from '../components/sections/Footer.astro';
import { getNeighborhoods } from '../lib/content/neighborhoods';

const neighborhoods = await getNeighborhoods();

const nav = [
  { label: 'For Owners', href: '/owners' },
  { label: 'Design', href: '/home-designs' },
  { label: 'Case studies', href: '/home-designs#case-studies' },
  { label: 'Blog', href: '/blog' },
];
const cta = { label: 'Free estimate', href: '/owners#estimate' };
---

<Base title="San Diego Neighborhoods We Serve | Cardo Vacation Rentals" description="Cardo manages luxury short-term rentals across San Diego — La Jolla, Pacific Beach, Del Mar, Encinitas, Carlsbad, and Coronado. Local experts since 2013.">
  <MarketingHeader {nav} {cta} />

  <main>
    <!-- NEIGHBORHOODS INDEX -->
    <section class="section-pad" style="padding-top:128px" data-screen-label="Neighborhoods">
      <div class="section-wrap">
        <div class="section-head reveal" style="max-width:720px">
          <p class="eyebrow">Where we manage</p>
          <h1 style="margin:8px 0 14px">Local experts across coastal San Diego.</h1>
          <p class="lede muted">Cardo manages luxury short-term rentals throughout San Diego's best coastal markets. Each neighborhood has its own demand curve — and we design, price, and run every home to its local opportunity.</p>
        </div>
        <div class="nh-index" data-nh-grid data-cms="neighborhoods">
          {neighborhoods.map((n) => (
            <a class="nh-card reveal" href={`/neighborhoods/${n.slug}`} data-nh-id={n.slug}>
              <img src={n.img} alt={n.name} loading="lazy" />
              <div class="nh-card__scrim"></div>
              <div class="nh-card__label"><div class="nh-card__name">{n.name}</div><div class="nh-card__note">{n.note}</div></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta" data-screen-label="CTA">
      <div class="cta__inner reveal">
        <p class="eyebrow">Local experts, since 2013</p>
        <h2>See what your San Diego home could earn.</h2>
        <p>A data-backed projection for your market — no obligation, usually within one business day.</p>
        <a href="/owners#estimate" class="btn btn-lg">Schedule a consultation</a>
      </div>
    </section>
  </main>

  <Footer />
  <!-- Full seed data for the inline admin editor (used only when signed in as
       admin and the CMS is empty). Ignored by regular visitors. -->
  <script type="application/json" data-nh-seed set:html={JSON.stringify(neighborhoods)}></script>
</Base>

<script>
  import '../scripts/reveal.js';
  import '../scripts/neighborhoods.js';
</script>

<style>
  .nh-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin: 0 0 8px; }
  .nh-stat { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 22px; box-shadow: var(--shadow-sm); }
  .nh-stat .v { font-family: var(--font-display); font-weight: 500; font-size: 1.7rem; color: var(--ink); line-height: 1; }
  .nh-stat .l { font-size: .82rem; color: var(--muted); margin-top: 8px; }
  .nh-body { display: grid; grid-template-columns: 1.15fr .85fr; gap: 56px; align-items: start; }
  .nh-body p { font-size: 1.08rem; line-height: 1.7; color: var(--ink-soft); margin: 0 0 1.2em; }
  .nh-highlights { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .nh-highlights li { display: flex; gap: 12px; align-items: flex-start; color: var(--ink-soft); font-size: 1rem; }
  .nh-highlights svg { flex: none; margin-top: 3px; }
  .nh-aside { background: var(--cream-2); border-radius: var(--radius-lg); padding: 28px; position: sticky; top: 90px; }
  .nh-aside h3 { font-size: 1.2rem; margin: 0 0 8px; }
  .nh-aside p { font-size: .96rem; color: var(--muted); line-height: 1.55; margin: 0 0 18px; }
  @media (max-width: 860px) { .nh-body { grid-template-columns: 1fr; gap: 30px; } .nh-aside { position: static; } }
  .nh-index { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .nh-card { position: relative; border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 3/2; display: block; isolation: isolate; }
  .nh-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
  .nh-card:hover img { transform: scale(1.06); }
  .nh-card__scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, transparent 40%, rgba(8,18,28,.8)); }
  .nh-card__label { position: absolute; left: 20px; bottom: 18px; z-index: 2; color: #fff; }
  .nh-card__name { font-family: var(--font-display); font-size: 1.5rem; }
  .nh-card__note { font-size: .85rem; color: rgba(255,255,255,.82); margin-top: 2px; }
  @media (max-width: 900px) { .nh-index { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .nh-index { grid-template-columns: 1fr; } }
</style>

---
import Layout from "../layouts/Layout.astro";
import LeadForm from "../components/site/LeadForm.astro";
import {
  SITE, STATS, PILLARS, CASE_STUDIES, GALLERY, TESTIMONIALS,
  NEIGHBORHOODS, HOW_IT_WORKS, FAQS,
} from "../lib/site-config.js";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: FAQS.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const ratingSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Vacation rental property management",
  provider: { "@type": "LodgingBusiness", name: SITE.name },
  areaServed: "San Diego County, California",
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "180" },
};

const icons = {
  spark: "M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4z",
  ledger: "M5 3h11l3 3v15H5zM9 8h6M9 12h6M9 16h4",
  shield: "M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z",
  palette: "M12 3a9 9 0 100 18c1.7 0 2-1.3 1.2-2.3-.8-1 .1-2.2 1.3-2.2H17a4 4 0 004-4c0-5-4-9.5-9-9.5zM7.5 12a1.2 1.2 0 110-2.4 1.2 1.2 0 010 2.4zm3-4a1.2 1.2 0 110-2.4 1.2 1.2 0 010 2.4zm4 0a1.2 1.2 0 110-2.4 1.2 1.2 0 010 2.4z",
};
---

<Layout path="/" schema={[ratingSchema, faqSchema]}>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">San Diego · Luxury STR Management</span>
        <h1>The homes guests remember aren't managed.<br /><em>They're cared for.</em></h1>
        <p class="lede">
          Cardo runs your San Diego vacation rental like a luxury hospitality brand —
          marketed by pros, accounted to the dollar, and maintained so it never slips.
          You earn more and never think about it.
        </p>
        <div class="hero-cta">
          <a href="/owners#estimate" class="btn btn-lg">Get your free revenue estimate</a>
          <a href="/#design" class="btn btn-ghost btn-lg">See our homes</a>
        </div>
        <ul class="hero-trust">
          <li><span class="divider-dot">●</span> Airbnb Superhost standard</li>
          <li><span class="divider-dot">●</span> Real-time owner dashboard</li>
          <li><span class="divider-dot">●</span> No setup fees</li>
        </ul>
      </div>

      <div class="hero-card" data-reveal>
        <div class="photo hero-photo" style="--ph-a:#15324a; --ph-b:#1f6f6b;">
          <span class="photo-meta">La Jolla</span>
          <span class="photo-tag">Bluff-top villa · booked 92% of nights</span>
        </div>
        <div class="hero-floating card">
          <strong>+24%</strong>
          <span>avg. revenue over market</span>
        </div>
      </div>
    </div>

    <div class="hero-stats">
      <div class="container stats-row">
        {STATS.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TRUST STRIP ===================== -->
  <section class="section-sm surface-paper trust-strip">
    <div class="container">
      <p class="center muted trust-lead">Trusted by San Diego homeowners across the coast</p>
      <div class="trust-logos">
        <span>Airbnb&nbsp;Superhost</span><span>Vrbo&nbsp;Premier</span><span>Booking.com</span>
        <span>Google&nbsp;4.9★</span><span>STRO&nbsp;Compliant</span>
      </div>
    </div>
  </section>

  <!-- ===================== PILLARS ===================== -->
  <section class="section" id="why">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">Why owners switch to Cardo</span>
        <h2 class="center">Full-service, genuinely. Not a call center with a logo.</h2>
        <p class="lede center mx-auto" style="max-width: 58ch;">
          The big national managers automate you into an average result. We do the four things
          that actually move your return — and we do all of them in-house.
        </p>
      </div>
      <div class="grid cols-4 pillars">
        {PILLARS.map((p) => (
          <article class="card pillar" data-reveal>
            <span class="pillar-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[p.icon]} />
              </svg>
            </span>
            <h3>{p.title}</h3>
            <p class="muted">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== RESULTS / CASE STUDIES ===================== -->
  <section class="section surface-ink" id="results">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">Real homes, real numbers</span>
        <h2 class="center">Owners earn more with Cardo — here's the receipts.</h2>
        <p class="lede center mx-auto" style="max-width: 56ch; color: rgba(248,243,236,0.74);">
          Trailing-12-month gross revenue on homes we manage, versus their San Diego market comp.
        </p>
      </div>
      <div class="grid cols-4 results-grid">
        {CASE_STUDIES.map((c) => (
          <article class="result-card" data-reveal>
            <div class="photo result-photo" style={`--ph-a:${c.grad[0]}; --ph-b:${c.grad[1]};`}>
              <span class="photo-meta">{c.neighborhood}</span>
              <span class="photo-tag">{c.beds}</span>
            </div>
            <div class="result-body">
              <strong class="result-gross">{c.gross}</strong>
              <span class="result-name">{c.home}</span>
              <span class="result-lift">{c.lift}</span>
            </div>
          </article>
        ))}
      </div>
      <p class="center results-note">Figures are illustrative of portfolio performance. Your estimate is built from your home's specifics.</p>
    </div>
  </section>

  <!-- ===================== DESIGN / DECOR SHOWCASE ===================== -->
  <section class="section" id="design">
    <div class="container">
      <div class="section-head split-head" data-reveal>
        <div>
          <span class="eyebrow">Design that earns more</span>
          <h2>Homes guests screenshot are homes that book out.</h2>
        </div>
        <p class="lede" style="max-width: 42ch;">
          Our in-house stylists stage every home to photograph beautifully and live well —
          the difference between a listing that blends in and one that commands a premium.
        </p>
      </div>
      <div class="gallery">
        {GALLERY.map((g) => (
          <div class={`photo gallery-tile span-${g.span}`} style={`--ph-a:${g.grad[0]}; --ph-b:${g.grad[1]};`} data-reveal>
            <span class="photo-meta">{g.meta}</span>
            <span class="photo-tag">{g.tag}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="section surface-cream2" id="how">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">From hello to hands-off</span>
        <h2 class="center">Three steps to a better-run home.</h2>
      </div>
      <div class="grid cols-3 steps">
        {HOW_IT_WORKS.map((s) => (
          <article class="step" data-reveal>
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p class="muted">{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TRANSPARENCY BAND ===================== -->
  <section class="section">
    <div class="container transparency card">
      <div class="transparency-copy" data-reveal>
        <span class="eyebrow">Transparent by default</span>
        <h2>See every dollar, any time you want.</h2>
        <p class="lede">
          Most owners leave their last manager over fuzzy statements and slow answers.
          With Cardo you get a real-time dashboard, itemized monthly payouts, and a team
          that picks up. No mystery fees, ever.
        </p>
        <ul class="check-list">
          <li>Real-time bookings, payouts &amp; expenses</li>
          <li>Itemized monthly owner statements</li>
          <li>Post-stay inspection reports with photos</li>
          <li>Sub-hour response on urgent maintenance</li>
        </ul>
        <a href="/portal/agreements" class="link-arrow">Preview the owner portal →</a>
      </div>
      <div class="transparency-visual" data-reveal>
        <div class="dash card">
          <div class="dash-row dash-head"><span>This month</span><strong>$18,420</strong></div>
          <div class="dash-bar"><i style="width:84%"></i></div>
          <div class="dash-line"><span>Bookings</span><span>14</span></div>
          <div class="dash-line"><span>Occupancy</span><span>88%</span></div>
          <div class="dash-line"><span>Avg. nightly</span><span>$642</span></div>
          <div class="dash-line"><span>Maintenance</span><span class="ok">All clear</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="section surface-ink" id="testimonials">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">What owners say</span>
        <h2 class="center">The kind of management you stop worrying about.</h2>
      </div>
      <div class="grid cols-3 testimonials">
        {TESTIMONIALS.map((t) => (
          <figure class="testimonial" data-reveal>
            <div class="stars" aria-label="5 out of 5">★★★★★</div>
            <blockquote>“{t.quote}”</blockquote>
            <figcaption>
              <strong>{t.name}</strong>
              <span>{t.home}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== NEIGHBORHOODS ===================== -->
  <section class="section" id="neighborhoods">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow center">Where we manage</span>
        <h2 class="center">Local experts, coast to coast of the county.</h2>
        <p class="lede center mx-auto" style="max-width: 54ch;">
          Pricing, permits, and guest expectations differ block to block. We know yours.
        </p>
      </div>
      <div class="grid cols-4 hoods">
        {NEIGHBORHOODS.map((n) => (
          <a class="hood card" href="/owners#estimate" data-reveal>
            <strong>{n.name}</strong>
            <span class="muted">{n.note}</span>
            <span class="hood-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA + FORM ===================== -->
  <section class="section surface-cream2" id="estimate">
    <div class="container cta-grid">
      <div class="cta-copy" data-reveal>
        <span class="eyebrow">Free property analysis</span>
        <h2>Find out what your home could earn.</h2>
        <p class="lede">
          Tell us a little about your place and we'll send a data-backed revenue projection
          for your San Diego market — plus exactly how we'd run it. No pressure, no obligation.
        </p>
        <ul class="check-list">
          <li>Custom revenue projection in 1 business day</li>
          <li>Transparent, all-in pricing quote</li>
          <li>A real local expert — not a chatbot</li>
        </ul>
      </div>
      <div data-reveal>
        <LeadForm />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    background:
      radial-gradient(80% 120% at 85% -10%, rgba(237, 60, 120, 0.08), transparent 55%),
      linear-gradient(180deg, var(--cream), var(--cream-2));
    padding-top: clamp(48px, 7vw, 92px);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
    padding-bottom: clamp(48px, 7vw, 88px);
  }
  .hero-copy h1 em { font-style: italic; color: var(--rose); }
  .hero-copy .lede { max-width: 52ch; margin-top: 18px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin: 30px 0 26px; }
  .hero-trust { list-style: none; display: flex; flex-wrap: wrap; gap: 22px; padding: 0; margin: 0; font-size: 0.9rem; color: var(--ink-soft); font-weight: 500; }
  .hero-trust .divider-dot { font-size: 0.6rem; margin-right: 6px; }

  .hero-card { position: relative; }
  .hero-photo { aspect-ratio: 4 / 5; box-shadow: var(--shadow-lg); }
  .hero-floating {
    position: absolute; left: -22px; bottom: 34px;
    padding: 16px 22px; display: flex; flex-direction: column;
    background: #fff;
  }
  .hero-floating strong { font-family: var(--font-display); font-size: 1.9rem; color: var(--rose); line-height: 1; }
  .hero-floating span { font-size: 0.82rem; color: var(--muted); }

  .hero-stats { border-top: 1px solid var(--line); background: rgba(255,255,255,0.4); }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding-block: 30px; }
  .stat { display: flex; flex-direction: column; gap: 4px; text-align: center; }
  .stat-value { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); color: var(--ink); }
  .stat-label { font-size: 0.86rem; color: var(--muted); }

  /* ---------- Trust strip ---------- */
  .trust-lead { font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 18px; }
  .trust-logos { display: flex; flex-wrap: wrap; justify-content: center; gap: 14px 36px; font-family: var(--font-display); font-size: 1.15rem; color: var(--ink-70); }

  /* ---------- Section heads ---------- */
  .section-head { margin-bottom: 52px; }
  .split-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap; }
  .split-head h2 { margin: 0; max-width: 18ch; }

  /* ---------- Pillars ---------- */
  .pillar { padding: 30px 26px; }
  .pillar-icon {
    display: inline-flex; width: 52px; height: 52px; border-radius: 14px;
    align-items: center; justify-content: center; margin-bottom: 18px;
    background: rgba(237, 60, 120, 0.1); color: var(--rose);
  }
  .pillar-icon svg { width: 26px; height: 26px; }
  .pillar h3 { font-size: 1.22rem; }

  /* ---------- Results ---------- */
  .results-grid { margin-top: 8px; }
  .result-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(248,243,236,0.12); border-radius: var(--radius-lg); overflow: hidden; }
  .result-photo { aspect-ratio: 4 / 3; border-radius: 0; }
  .result-body { padding: 20px 20px 22px; display: flex; flex-direction: column; gap: 4px; }
  .result-gross { font-family: var(--font-display); font-size: 1.6rem; color: #fff; }
  .result-name { font-size: 0.95rem; color: rgba(248,243,236,0.8); }
  .result-lift { font-size: 0.85rem; font-weight: 600; color: var(--rose); margin-top: 4px; }
  .results-note { margin-top: 34px; font-size: 0.82rem; color: rgba(248,243,236,0.5); }

  /* ---------- Gallery ---------- */
  .gallery { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 220px; gap: 18px; }
  .gallery-tile { grid-row: span 1; }
  .gallery-tile.span-2 { grid-column: span 2; }
  @media (max-width: 860px) { .gallery { grid-template-columns: repeat(2, 1fr); } .gallery-tile.span-2 { grid-column: span 2; } }
  @media (max-width: 520px) { .gallery { grid-template-columns: 1fr; grid-auto-rows: 200px; } .gallery-tile.span-2 { grid-column: span 1; } }

  /* ---------- Steps ---------- */
  .steps { counter-reset: step; }
  .step { padding: 8px 4px; }
  .step-num { font-family: var(--font-display); font-size: 2.4rem; color: var(--gold); display: block; margin-bottom: 8px; }
  .step h3 { font-size: 1.3rem; }

  /* ---------- Transparency ---------- */
  .transparency { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items: center; padding: clamp(28px, 4vw, 56px); }
  .check-list { list-style: none; padding: 0; margin: 22px 0 26px; display: grid; gap: 12px; }
  .check-list li { position: relative; padding-left: 32px; color: var(--ink-soft); }
  .check-list li::before {
    content: "✓"; position: absolute; left: 0; top: 0;
    width: 22px; height: 22px; border-radius: 50%;
    background: rgba(31, 111, 107, 0.14); color: var(--sea);
    display: grid; place-items: center; font-size: 0.78rem; font-weight: 700;
  }
  .dash { padding: 26px; }
  .dash-row { display: flex; justify-content: space-between; align-items: baseline; }
  .dash-head span { color: var(--muted); font-size: 0.9rem; }
  .dash-head strong { font-family: var(--font-display); font-size: 1.9rem; }
  .dash-bar { height: 10px; border-radius: 999px; background: var(--cream-2); margin: 14px 0 20px; overflow: hidden; }
  .dash-bar i { display: block; height: 100%; background: linear-gradient(90deg, var(--rose), var(--gold)); }
  .dash-line { display: flex; justify-content: space-between; padding: 10px 0; border-top: 1px solid var(--line); font-size: 0.95rem; }
  .dash-line .ok { color: var(--sea); font-weight: 600; }

  /* ---------- Testimonials ---------- */
  .testimonial { margin: 0; padding: 28px 26px; background: rgba(255,255,255,0.05); border: 1px solid rgba(248,243,236,0.12); border-radius: var(--radius-lg); }
  .stars { color: var(--gold); letter-spacing: 2px; margin-bottom: 14px; }
  .testimonial blockquote { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.55; color: #fff; }
  .testimonial figcaption { display: flex; flex-direction: column; gap: 2px; }
  .testimonial figcaption strong { color: #fff; }
  .testimonial figcaption span { font-size: 0.88rem; color: rgba(248,243,236,0.6); }

  /* ---------- Neighborhoods ---------- */
  .hood { position: relative; padding: 24px; display: flex; flex-direction: column; gap: 5px; transition: transform 0.18s var(--ease), box-shadow 0.18s var(--ease), border-color 0.18s var(--ease); }
  .hood strong { font-family: var(--font-display); font-size: 1.25rem; }
  .hood span.muted { font-size: 0.9rem; }
  .hood-arrow { position: absolute; top: 22px; right: 22px; color: var(--rose); opacity: 0; transition: opacity 0.18s var(--ease), transform 0.18s var(--ease); }
  .hood:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: rgba(237,60,120,0.4); }
  .hood:hover .hood-arrow { opacity: 1; transform: translateX(4px); }

  /* ---------- Final CTA ---------- */
  .cta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-card { max-width: 440px; }
    .transparency, .cta-grid { grid-template-columns: 1fr; gap: 36px; }
  }
  @media (max-width: 620px) {
    .stats-row { grid-template-columns: 1fr 1fr; gap: 18px; }
    .hero-floating { left: 12px; }
  }
</style>

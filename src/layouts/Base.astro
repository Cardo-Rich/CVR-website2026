---
import '../styles/styles.css';
import '../styles/site.css';
import '../styles/menu.css';
import { company } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** Social share image — absolute or root-relative path. Defaults to the brand OG card. */
  image?: string;
  /** Alt text describing the share image (accessibility + some crawlers). */
  imageAlt?: string;
  /** og:type — "website" for most pages, "article" for blog posts. */
  type?: 'website' | 'article';
  /** Set true on pages that must not be indexed (e.g. thank-you, gated flows). */
  noindex?: boolean;
  /** Override the canonical URL. Defaults to the current page's clean URL. */
  canonical?: string;
  /** Article timestamps (ISO 8601) — only used when type === "article". */
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title = `${company.name} — Luxury STR management, San Diego`,
  description = "San Diego's design-led vacation rental manager — a 5-star Superhost with 2,000+ reviews. Pro marketing, transparent accounting, and care that never lets your home slip.",
  image = '/assets/og/og-default.jpg',
  imageAlt = 'Cardo Vacation Rentals — luxury San Diego vacation homes for unforgettable stays',
  type = 'website',
  noindex = false,
  canonical,
  publishedTime,
  modifiedTime,
} = Astro.props;

// Resolve absolute URLs against the configured site (astro.config.mjs → site).
// Falls back gracefully if Astro.site is undefined (e.g. during some tooling).
const siteOrigin = Astro.site?.origin ?? 'https://cardorentals.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteOrigin).href;
const imageUrl = new URL(image, siteOrigin).href;

// Site-wide organization schema — helps Google/AI answer engines understand who
// Cardo is, the service area, and the 5-star track record. Rendered once per page.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteOrigin}/#organization`,
  name: company.name,
  description:
    'Design-led luxury short-term rental management on the San Diego coast. A 5-star Airbnb Superhost since 2013 with 2,000+ guest reviews.',
  url: siteOrigin,
  telephone: company.phoneHref,
  image: imageUrl,
  logo: `${siteOrigin}/assets/logo-horizontal-color.png`,
  priceRange: '$$$',
  areaServed: [
    'La Jolla',
    'Pacific Beach',
    'Del Mar',
    'Encinitas',
    'Coronado',
    'Carlsbad',
    'San Diego',
  ].map((name) => ({ '@type': 'City', name })),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'San Diego',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '2000',
  },
};
const orgSchemaJson = JSON.stringify(orgSchema);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Tag Manager — container GTM-TT9LPF7 (account "Cardo Furnished
         Rentals"). GA4 (G-V5MWW8XE4X) is configured as a Google Tag INSIDE this
         container, firing on Initialization - All Pages. Manage all analytics/
         marketing tags in the GTM UI — do NOT also hardcode GA4 or the Meta
         Pixel here, or events will be counted twice. -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TT9LPF7');</script>
    <!-- End Google Tag Manager -->

    <link rel="icon" href="/assets/favicon.svg" />
    <link rel="alternate icon" href="/assets/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#102234" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, WhatsApp, …) -->
    <meta property="og:site_name" content={company.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_US" />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <!-- Twitter / X large-image card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script type="application/ld+json" is:inline set:html={orgSchemaJson} />

    <!-- Per-page head extras (page-specific JSON-LD, preloads, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TT9LPF7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <!-- Inline admin layer: activates only for signed-in admins; a no-op for
         every public visitor beyond one idle-time auth check. -->
    <script>
      import('../scripts/admin/inline.ts');
    </script>
  </body>
</html>

<style>
  body {
    background: var(--surface-page); /* V3: white */
  }
</style>
